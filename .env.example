# Banti environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Required ──────────────────────────────────────────────────────────────────

# Deepgram API key (https://console.deepgram.com)
export DEEPGRAM_API_KEY=

# Anthropic API key — used for camera & screen VLM descriptions (https://console.anthropic.com)
export ANTHROPIC_API_KEY=

# ── Optional — Speech-to-text ─────────────────────────────────────────────────

# Deepgram model (default: nova-2)
# export DEEPGRAM_MODEL=nova-2

# Transcript language (default: en)
# export DEEPGRAM_LANGUAGE=en

# ── Optional — Vision (camera + screen) ───────────────────────────────────────

# Vision provider (default: claude — the only supported value for now)
# export VISION_PROVIDER=claude

# Anthropic model used for vision calls (default: claude-haiku-4-5)
# export ANTHROPIC_VISION_MODEL=claude-haiku-4-5

# ── Optional — Camera perception ──────────────────────────────────────────────

# How often CameraFrameActor publishes a frame, in milliseconds (default: 200)
# export CAMERA_CAPTURE_INTERVAL_MS=200

# Minimum seconds between VLM calls for camera scene description (default: 5)
# export SCENE_DESCRIPTION_INTERVAL_S=5

# Prompt sent to the VLM for each camera frame (optional override)
# export SCENE_DESCRIPTION_PROMPT=Describe the visual scene concisely, focusing on people, objects, and activities.

# ── Optional — Screen perception ──────────────────────────────────────────────

# How often ScreenCaptureActor publishes a frame, in milliseconds (default: 1000)
# export SCREEN_CAPTURE_INTERVAL_MS=1000

# Minimum seconds between VLM calls for screen description (default: 10)
# export SCREEN_DESCRIPTION_INTERVAL_S=10

# Prompt sent to the VLM for each screen frame (optional override)
# export SCREEN_DESCRIPTION_PROMPT=Describe what is shown on this computer screen. Focus on the application in use, visible text, open documents, and what the user appears to be doing.

# ── Optional — Accessibility (AXFocusActor) ───────────────────────────────────

# Debounce window for kAXValueChangedNotification, in milliseconds (default: 50)
# export AX_DEBOUNCE_MS=50

# Maximum selected-text length carried in AXFocusEvent.selectedText (default: 2000)
# export AX_SELECTED_TEXT_MAX_CHARS=2000
